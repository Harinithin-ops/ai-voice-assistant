# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Preserve CRLF for Windows-specific files if any
*.bat text eol=crlf
*.cmd text eol=crlf
